# Convex
# (These are auto-populated when you run `npx convex dev`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk
# Get from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ngrok (for sharing demos)
# Get domain from: https://dashboard.ngrok.com/domains
NGROK_DOMAIN=

# Observability — Sentry (optional; leave empty for stub mode)
# When NEXT_PUBLIC_SENTRY_DSN is empty/unset, Sentry is a complete no-op
# (no init, no network). The other three are build-time only and only used
# to upload source maps when present — typically set in Vercel env, not here.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
